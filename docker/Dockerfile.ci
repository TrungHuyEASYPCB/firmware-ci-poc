ARG BASE_IMAGE=ubuntu:24.04

FROM ${BASE_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    git \
    gcc \
    g++ \
    python3 \
    python3-yaml \
    python3-pytest \
    shellcheck \
    cmake \
    ninja-build \
    gperf \
    device-tree-compiler \
    file \
    make \
    xz-utils \
    unzip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /work
